#!/bin/bash

# Start complex flow control test

echo "Starting complex flow control test"

# Function to generate Fibonacci numbers
fibonacci() {
  local n=$1
  local a=0 b=1 count=0
  while [ $count -lt $n ]; do
    echo "$a"
    local temp=$((a + b))
    a=$b
    b=$temp
    count=$((count + 1))
  done
}

# Use the function

echo "First 5 Fibonacci numbers:"
fibonacci 5

# Main loop with complex control structures
for i in {1..5}; do
  echo "Iteration $i"
  if (( i % 2 == 0 )); then
    echo "$i is even"
    for j in {1..3}; do
      echo "  Sub-iteration $j"
      if (( j % 2 == 0 )); then
        echo "  Sub-iteration $j is even"
        if (( j == 2 )); then
          echo "  Sub-iteration $j is the middle"
          break
        fi
      else
        echo "  Sub-iteration $j is odd"
      fi
    done
  else
    echo "$i is odd"
    case $i in
      1) echo "  First iteration";;
      3) echo "  Third iteration";;
      5) echo "  Fifth iteration";;
    esac
  fi

done

# End of script

echo "Completed"
EOF
chmod +x ~/agent_test/test2.3.sh
