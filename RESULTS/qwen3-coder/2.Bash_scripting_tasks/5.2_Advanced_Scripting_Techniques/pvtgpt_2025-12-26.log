# Example script using complex data structures like arrays

# Declare and initialize arrays
fruits=("apple" "banana" "orange" "grape")
colors=("red" "blue" "green" "yellow")
numbers=(10 20 30 40 50)

# Associative array (hash map)
declare -A fruit_colors
fruit_colors["apple"]="red"
fruit_colors["banana"]="yellow"
fruit_colors["orange"]="orange"
fruit_colors["grape"]="purple"

# Print arrays
echo "Fruits array:"
for fruit in "${fruits[@]}"; do
    echo "  $fruit"
done

echo -e "\nNumbers array:"
for num in "${numbers[@]}"; do
    echo "  $num"
done

echo -e "\nAssociative array fruit_colors:"
for fruit in "${!fruit_colors[@]}"; do
    echo "  $fruit: ${fruit_colors[$fruit]}"
done

# Array operations
echo -e "\nArray operations:"
echo "Length of fruits array: ${#fruits[@]}"
echo "Length of numbers array: ${#numbers[@]}"

# Add element to array
fruits+=("mango")
echo "After adding mango to fruits array:"
for fruit in "${fruits[@]}"; do
    echo "  $fruit"
done

# Sort numbers array
echo -e "\nSorted numbers:"
sorted_numbers=($(printf '%s\n' "${numbers[@]}" | sort -n))
for num in "${sorted_numbers[@]}"; do
    echo "  $num"
done

# Function using arrays
sum_array() {
    local arr=("$@")
    local sum=0
    for num in "${arr[@]}"; do
        ((sum += num))
    done
    echo $sum
}

echo -e "\nSum of numbers array: $(sum_array "${numbers[@]}")"' > ~/agent_test/test5.2.sh && chmod +x ~/agent_test/test5.2.sh
