#!/bin/bash
# Script to verify the integrity of encrypted backups using checksums

# Check if the backup file and checksum file are provided
if [ $# -ne 2 ]; then
  echo "Usage: $0 <backup_file> <checksum_file>"
  exit 1
fi

BACKUP_FILE="$1"
CHECKSUM_FILE="$2"

# Check if files exist
if [ ! -f "$BACKUP_FILE" ]; then
  echo "Error: Backup file $BACKUP_FILE not found."
  exit 1
fi

if [ ! -f "$CHECKSUM_FILE" ]; then
  echo "Error: Checksum file $CHECKSUM_FILE not found."
  exit 1
fi

# Calculate checksum of the backup file
CALCULATED_CHECKSUM=$(openssl dgst -sha256 "$BACKUP_FILE" | awk {print })

# Read the expected checksum from the checksum file
EXPECTED_CHECKSUM=$(cat "$CHECKSUM_FILE")

# Compare checksums
if [ "$CALCULATED_CHECKSUM" = "$EXPECTED_CHECKSUM" ]; then
  echo "Backup integrity verified: Checksums match."
  exit 0
else
  echo "Backup integrity check failed: Checksums do not match."
  exit 1
fi
```

This script verifies the integrity of encrypted backups using SHA256 checksums. It takes two arguments: the backup file and the checksum file. It checks if both files exist, calculates the checksum of the backup file, and compares it with the expected checksum from the checksum file.

